quarkus.datasource.db-kind=postgresql
quarkus.datasource.username=${DB_USERNAME}
quarkus.datasource.password=${DB_PASSWORD}
quarkus.datasource.jdbc.url=${JDBC_DATABASE_URL}
quarkus.datasource.reactive.url=${REACTIVE_DATABASE_URL}

quarkus.flyway.migrate-at-start=true
quarkus.flyway.locations=db/migration

quarkus.hibernate-orm.schema-management.strategy=none

oficina.mercado-pago.enabled=${OFICINA_MERCADO_PAGO_ENABLED:false}
oficina.mercado-pago.access-token=${OFICINA_MERCADO_PAGO_ACCESS_TOKEN:}
oficina.mercado-pago.payer-email=${OFICINA_MERCADO_PAGO_PAYER_EMAIL:cliente.local@oficina.com}
quarkus.rest-client.mercado-pago-api.url=${OFICINA_MERCADO_PAGO_API_URL:https://api.mercadopago.com}

%dev.quarkus.datasource.devservices.enabled=true
%dev.quarkus.datasource.devservices.port=${DEV_POSTGRES_PORT:32771}
%dev.quarkus.flyway.clean-at-start=true
%dev.quarkus.flyway.migrate-at-start=true

%test.quarkus.datasource.devservices.enabled=true
%test.quarkus.flyway.clean-at-start=true
%test.quarkus.flyway.migrate-at-start=true

%prod.quarkus.flyway.clean-at-start=false
%prod.quarkus.flyway.migrate-at-start=true
